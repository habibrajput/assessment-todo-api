            "type": "default",
            "enabled": true,
            "description": "Base URL for the API. Change to your server address if not running locally."
        },
        {
            "key": "token",
            "value": "",
            "type": "secret",
            "enabled": true,
            "description": "JWT Bearer token. Auto-populated by the Login request test script."
        },
        {
            "key": "verification_code",
            "value": "",
            "type": "default",
            "enabled": true,
            "description": "Paste the verification code from the email link here before calling Verify Email."
        },
        {
            "key": "todo_id",
            "value": "",
            "type": "default",
            "enabled": true,
            "description": "Auto-populated by the Create Todo and List Todos test scripts."
        }
    ],
    "_postman_variable_scope": "environment"
}
