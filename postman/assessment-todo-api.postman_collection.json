        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access_token', () => pm.expect(res.records.access_token).to.be.a('string'));",
                  "// Auto-save the token so all protected requests use it",
                  "if (res.records && res.records.access_token) {",
                  "    pm.environment.set('token', res.records.access_token);",
                  "    console.log('Token saved to environment.');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"demo@example.com\",\n    \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Returns a JWT bearer token on success. The test script automatically saves the token to the `token` environment variable – all subsequent protected requests will use it."
          },
          "response": []
        },
