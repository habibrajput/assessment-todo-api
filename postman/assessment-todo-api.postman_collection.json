      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Outcome is SUCCESS', () => pm.expect(res._metadata.outcome).to.eql('SUCCESS'));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Demo User\",\n    \"email\": \"demo@example.com\",\n    \"password\": \"password\",\n    \"password_confirmation\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a new unverified user account and sends a verification e-mail.\n\n**Required fields:** name, email, password, password_confirmation\n\n**After this call:** check your Mailtrap inbox, copy the verification code from the URL and call the Verify Email endpoint."
          },
          "response": []
