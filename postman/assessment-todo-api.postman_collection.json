    {
      "name": "Todos",
      "item": [
        {
          "name": "List Todos (page 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Records has pagination', () => pm.expect(res.records).to.have.property('pagination'));",
                  "pm.test('Records has todos array', () => pm.expect(res.records.todos).to.be.an('array'));",
                  "// Save the first todo id for later tests",
                  "if (res.records.todos && res.records.todos.length > 0) {",
                  "    pm.environment.set('todo_id', res.records.todos[0].id);",
                  "    console.log('Saved todo_id:', res.records.todos[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
